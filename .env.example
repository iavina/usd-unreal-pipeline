# Local pipeline environment variables (copy to `.env` and customize)

# Default explore directory for local development
# PIPELINE_DEV_DIRECTORY=C:\path\to\test\assets

# Unreal editor launch (`pipeline editor`)
# PIPELINE_UNREAL_EDITOR=C:\Path\To\UnrealEditor.exe
# PIPELINE_UNREAL_PROJECT=C:\Path\To\YourGame.uproject
# Optional explicit Cmd binary for `pipeline editor --cmd`:
# PIPELINE_UNREAL_EDITOR_CMD=C:\Path\To\UnrealEditor-Cmd.exe

# Optional: Unreal Python startup search path (directories with init_unreal.py).
# If unset, interactive `pipeline editor` sets this to <repo>/scripts/startup.
# UE_PYTHONPATH is NOT the UnrealEditor.exe path.
# UE_PYTHONPATH=C:\path\to\pipeline\scripts\startup
